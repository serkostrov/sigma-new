# Supabase (required)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
VITE_SUPABASE_PROJECT_ID=your-project-id

# SSR fallback (optional if VITE_* are set at build time)
# ВАЖНО: для self-hosted Supabase (sslip.io и т.п.) используйте https://, не http://
# HTTP редиректит на HTTPS → браузер блокирует CORS preflight
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-anon-key

# Runtime (Dokploy / Docker)
HOST=0.0.0.0
PORT=8090
NODE_ENV=production
APP_URL=http://localhost:8090

# VK Chat (личные сообщения)
# Вариант 1: токен напрямую (проще для одного аккаунта)
VK_ACCESS_TOKEN=

# Вариант 2: OAuth через приложение VK
VK_APP_ID=
VK_APP_SECRET=
# Должен совпадать с Redirect URI в настройках приложения VK, например http://localhost:8090/chat
VK_REDIRECT_URI=http://localhost:8090/chat

# Supabase service role (опционально — чат работает через JWT пользователя)
SUPABASE_SERVICE_ROLE_KEY=

# Avito Chat (мессенджер)
# Получить в личном кабинете Авито → Настройки → API → Регистрация приложения
AVITO_CLIENT_ID=
AVITO_CLIENT_SECRET=
# Опционально — если не указан, определится через /core/v1/accounts/self
AVITO_USER_ID=
